<div id="<%= dom_id discussion %>" class="w-full sm:w-auto my-5 space-y-5">
  <div>
    <strong class="block font-medium mb-1">Book:</strong>
    <%= discussion.book %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Author:</strong>
    <%= discussion.author %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Description:</strong>
    <%= discussion.description %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Creator:</strong>
    <%= discussion.creator_id %>
  </div>
</div>
