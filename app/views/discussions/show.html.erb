<% content_for :title, "Showing discussion" %>

<div class="md:w-2/3 w-full">
  <h1 class="font-bold text-4xl">Showing discussion</h1>

  <%= render @discussion %>
  <div id="messages"><%= render(MessagesComponent.new(messages: @messages)) %></div>
  <%= render(MessageFormComponent.new(form_id: "message-form", message: @message, discussion: @discussion)) if user_signed_in? %>
  <%= link_to "Back to discussions", discussions_path, class: "w-full sm:w-auto text-center mt-2 sm:mt-0 sm:ml-2 rounded-md px-3.5 py-2.5 bg-gray-100 hover:bg-gray-50 inline-block font-medium" %>
  <% if current_user == @discussion.creator %>
    <%= link_to "Edit this discussion", edit_discussion_path(@discussion), class: "w-full sm:w-auto text-center rounded-md px-3.5 py-2.5 bg-gray-100 hover:bg-gray-50 inline-block font-medium" %>
    <%= button_to "Destroy this discussion", @discussion, method: :delete, form_class: "sm:inline-block mt-2 sm:mt-0 sm:ml-2", class: "w-full rounded-md px-3.5 py-2.5 text-white bg-red-600 hover:bg-red-500 font-medium cursor-pointer", data: { turbo_confirm: "Are you sure?" } %>
  <% end %>
  <div id="discussionId" style="display: none"><%= @discussion.id %></div>
</div>
