<!DOCTYPE html>
<html lang="en">
  <head>
    <title><%= content_for(:title) || "Symposium" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Symposium">
    <meta name="mobile-web-app-capable" content="yes">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Lobster+Two:ital,wght@0,400;0,700;1,400;1,700&family=Roboto:ital,wght@0,100..900;1,100..900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&icon_names=search" />
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>
    <%= favicon_link_tag 'favicon.ico' %>

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="font-roboto">
    <nav class="flex w-screen mt-4 mb-4">
      <h1 class="font-lobster flex-1  ml-8 text-5xl">symposium.</h1>
      <% if current_user %>
        <span class="flex flex-col mr-10 mb-3 ml-3 mt-3 pb-[0.1rem] relative after:content-[''] after:transition after:duration-300 after:bg-black after:absolute after:h-[0.1rem] after:w-full after:scale-x-0 hover:after:scale-x-100 after:box-border after:bottom-0"><%= link_to "Logout", destroy_user_session_path, data: { turbo_method: :delete }, class: 'button is-link text-xl' %></span>
      <% else %>
        <span class="flex flex-col mr-10 mb-3 ml-3 mt-3 pb-[0.1rem] relative after:content-[''] after:transition after:duration-300 after:bg-black after:absolute after:h-[0.1rem] after:w-full after:scale-x-0 hover:after:scale-x-100 after:box-border after:bottom-0"><%= link_to "Log-in", new_user_session_path, class: 'button is-link text-xl text-center font-medium' %></span>
      <% end %>
    </nav>
    <main class="container mx-auto mt-18 px-5">
      <div class="z-10 absolute bottom-4 right">
        <% flash.each do |type, msg| %>
          <p class="<%= type %>">
            <%= msg %>
          </p>
        <% end %>
        <% if defined?(resource) && resource.present? %>
          <%= render "devise/shared/error_messages", resource: resource %>
        <% end %>
      </div>
      <%= yield %>
    </main>
  </body>
</html>
